generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./placeholder.db"
}

model Resource {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  country   String
  color     String   @default("#4472C4")
  capacityH Int      @default(8)
  createdAt DateTime @default(now())

  assignments   Assignment[]
  holidays      Holiday[]
  vacations     Vacation[]
  timeEntries   TimeEntry[]
  resourceRates ProjectResourceRate[]
}

model Project {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  color          String
  status         String
  priority       String
  startDate      DateTime
  endDate        DateTime
  estimatedHours Int
  costPerHour    Float    @default(0)
  budgetHours    Float?
  projectType    String   @default("fixed")
  notes          String   @default("")
  createdAt      DateTime @default(now())

  assignments   Assignment[]
  timeEntries   TimeEntry[]
  resourceRates ProjectResourceRate[]
}

model Assignment {
  id             Int      @id @default(autoincrement())
  projectId      Int
  resourceId     Int
  moduleName     String
  percentage     Int
  startDate      DateTime
  endDate        DateTime
  estimatedHours Int

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model Holiday {
  id         Int      @id @default(autoincrement())
  resourceId Int
  date       DateTime
  name       String

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, date])
}

model Vacation {
  id         Int      @id @default(autoincrement())
  resourceId Int
  startDate  DateTime
  endDate    DateTime
  notes      String   @default("")

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model CountryHoliday {
  id      Int      @id @default(autoincrement())
  country String
  date    DateTime
  name    String

  @@unique([country, date])
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  userRoles UserRole[]
}

model Role {
  id        Int              @id @default(autoincrement())
  name      String           @unique

  userRoles UserRole[]
  pagePerms PagePermission[]
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model PagePermission {
  id     Int    @id @default(autoincrement())
  page   String
  roleId Int

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([page, roleId])
}

model TimeEntry {
  id         Int      @id @default(autoincrement())
  resourceId Int
  projectId  Int
  date       DateTime
  hours      Float

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([resourceId, projectId, date])
}

model ProjectResourceRate {
  id          Int     @id @default(autoincrement())
  projectId   Int
  resourceId  Int
  profile     String  @default("Developer")
  ratePerHour Float   @default(0)
  billable    Boolean @default(true)

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([projectId, resourceId])
}
